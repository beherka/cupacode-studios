# =====================================================
# Variables d'environnement — Cupacode Studios
# Copier ce fichier en .env.local et remplir les valeurs
# =====================================================

# Supabase — URL et clé publique (anon key)
# Disponibles dans : Dashboard Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici

# Supabase — Clé service (server-side uniquement, NE PAS exposer côté client)
# Disponible dans : Dashboard Supabase > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici

# URL publique du site (pour les meta Open Graph et le sitemap)
NEXT_PUBLIC_SITE_URL=https://cupacode-studios.com
